local function RefreshConsoleDisplay()
    if not Scroll_ConsoleOutput then return end
    for _, child in ipairs(Scroll_ConsoleOutput:GetChildren()) do
        if child:IsA("TextLabel") then
            local msgtype = child:GetAttribute("MessageType") or "INFO"
            if msgtype == "ERROR" then
                child.Visible = ConsoleConfig.showerror
            elseif msgtype == "WARN" then
                child.Visible = ConsoleConfig.showwarn
            elseif msgtype == "OUT" then
                child.Visible = ConsoleConfig.showoutput
            elseif msgtype == "INFO" then
                child.Visible = ConsoleConfig.showinfo
            else
                log("未知的消息类型: " .. tostring(msgtype), "warn")
            end
        end
    end
end

local function log(text, messagetype)
    if not ConsoleConfig.debuglogs then return end

    local mtype = messagetype or "out"

    if mtype == "out" and not ConsoleConfig.showoutput then return end
    if mtype == "warn" and not ConsoleConfig.showwarn then return end
    if mtype == "error" and not ConsoleConfig.showerror then return end
    
    if mtype == "error" then 
        error("[NVI] " .. text)
    elseif mtype == "warn" then
        warn("[NVI]", text)
    elseif mtype == "out" then
        print("[NVI]", text)
    else 
        warn("[NVI]", "这个消息属于未知频道!", text)
    end
end

local NavigationHistoryConfig = {
    maxhistory = 50,
    nowindex = 0,
    history = {}
}

local NavigationHistory = NavigationHistoryConfig

function NavigationHistory:Push(entry)
    if self.nowindex < #self.history then
        for i = #self.history, self.nowindex + 1, -1 do
            table.remove(self.history, i)
        end
    end
    if self.history[self.nowindex] == entry then return end
    table.insert(self.history, entry)
    self.nowindex = #self.history
end

function NavigationHistory:Back()
    if self.nowindex <= 1 then
        log("没有更早的导航历史了", "warn")
        return nil
    end
    self.nowindex -= 1
    return self.history[self.nowindex]
end

function NavigationHistory:Enter()
    if self.nowindex >= #self.history then
        log("没有更晚的导航历史了", "warn")
        return nil
    end
    self.nowindex += 1
    return self.history[self.nowindex]
end

