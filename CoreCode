    handler = function(args, _)
        if #args < 2 then
            return false, "命令参数不足：;chat <system(s)/normal(n)> <文本> [l33t]"
        end
        
        local channel = args[1]:lower()
        local message = table.concat(args, " ", 2, #args - (args[#args] == "l33t" and 1 or 0))
        local usel33t = args[#args]:lower() == "l33t"
        if usel33t then
            if not message then 
                return false, "命令参数不足，输入的消息为空！" 
            end
            local result = ""
            for i = 1, #message do
                local char = message:sub(i, i)
                if l33tmap[char] and math.random() < 0.4 then
                    result = result .. l33tmap[char]
                else
                    result = result .. char
                end
            end
            message = result
        end
        
        if channel == "system" or channel == "s" then
            TextChatService.TextChannels.RBXSystem:SendAsync(message)
            return true, "消息已发送到系统聊天" .. (usel33t and " (l33t 模式)" or "") .. "消息: " .. message
        elseif channel == "normal" or channel == "n" then
            TextChatService.TextChannels.RBXGeneral:SendAsync(message)
            return true, "消息已发送到普通聊天" .. (usel33t and " (l33t 模式)" or "") .. "消息: " .. message
        else
            return false, "无效的频道！请输入 'system/s' 或 'normal/n'"
        end
    end
})

RegisterCommand("consoleconfig", {
    aliases = {"cc"},
    usage = {";consoleconfig <all|nvi|filter> <值>"},
    description = "配置控制台显示选项",
    handler = function(args, _)
        if #args == 0 then
            return true, "用法：;consoleconfig <debug|maxdisplay|filter> <值>"
        end
        
        local option = args[1]:lower()
        if option == "debug" then
            ConsoleConfig.debuglogs = not ConsoleConfig.debuglogs
            return true, "已切换显示 NVI 日志：" .. tostring(ConsoleConfig.debuglogs)
        elseif option == "maxdisplay" and args[2] then
            local number = tonumber(args[2])
            if number and number > 0 then
                ConsoleConfig.maxmessages = number
                return true, "已设置最大消息数：" .. number
            else
                return false, "无效的数值!请输入正整数!"
            end
        elseif option == "filter" and args[2] then
            table.insert(ConsoleConfig.filterkeywords, args[2])
            return true, "已添加过滤关键词：" .. args[2]
        else 
            return false, "用法：;consoleconfig <debug|maxdisplay|filter> <值>"
        end
        return false, "未知错误"
    end
})

RegisterCommand("help", {
    aliases = {"?"},
    usage = {";help [指令名]"},
    description = "显示所有指令或查看特定指令的详细信息",
    handler = function(args, _)
        if #args == 0 then
            log("命令格式: <>内为必填项 []内为选填项", "out")
            log("========== 可用指令列表 ==========", "out")
            for cmdname, cmdinfo in pairs(commandlist) do
                local usage = table.concat(cmdinfo.usage, " / ")
                log(string.format("%s - %s - %s", cmdname, usage, cmdinfo.description), "out")
            end
            log("==================================", "out")
            return true, "已显示所有指令"
        else
            local targetcmd = args[1]:lower()
            local mainname = commandmap[targetcmd]
            if not mainname then
                return false, "未知指令：" .. targetcmd
            end
            local cmd = commandlist[mainname]
            log("========== 指令详情 ==========", "out")
            log(string.format("指令名：%s", cmd.main), "out")
            log(string.format("别名：%s", table.concat(cmd.aliases, ", ")), "out")
            log(string.format("用法：%s", table.concat(cmd.usage, " / ")), "out")
            log(string.format("描述：%s", cmd.description), "out")
            log("==============================", "out")
            return true, "已显示指令详情"
        end
        return false, "未知错误"
    end
})

